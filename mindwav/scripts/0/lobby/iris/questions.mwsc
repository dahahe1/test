i
options clear
checkflag _0.iris.branch 0
goto marker 0
checkflag _0.iris.branch A
goto marker A
checkflag _0.iris.branch A2
goto marker A2
checkflag _0.iris.branch AA
goto marker AA
checkflag _0.iris.branch AB
goto marker AB
checkflag _0.iris.branch AAA
goto marker AAA
checkflag _0.iris.branch ABA
goto marker ABA







marker 0
option add name "scripts/0_lobby_iris_questions_25" color pandora script "0/lobby/iris/A"
option add name "scripts/0_lobby_iris_questions_26" script "0/lobby/iris/bye_before_apologize"
goto marker end


marker A
